{
  "Jwt": {
    "Issuer": "https://api.mepauto.local",
    "Audience": "mepauto-client",
    "AccessTokenMinutes": 30,
    "RefreshTokenHours": 8
  },
  "DataDir": "/var/mepauto-data",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
