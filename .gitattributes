# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts MUST be LF (run on Linux VPS)
*.sh text eol=lf
*.bash text eol=lf

# Dockerfile + nginx conf MUST be LF
Dockerfile text eol=lf
*.conf text eol=lf
*.conf.template text eol=lf
docker-compose*.yml text eol=lf

# YAML/JSON LF for cross-platform compatibility
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Windows-specific files
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Source code: use platform default
*.cs text
*.csproj text
*.sln text
*.props text
*.wxs text
*.wixproj text

# Binary files
*.dll binary
*.pdb binary
*.png binary
*.jpg binary
*.ico binary
*.msi binary
*.rtf binary
