<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!--
    MEPAuto MSI installer — perUser only. Ship 6 version Revit DLL + 6 .addin manifest.

    Build flow:
      1. dotnet build MEPAuto.sln -c Release-2022..2027  (sinh bin/Release-{ver}/)
      2. ./installer/Build-MSI.ps1  (sinh Files_*.wxs + WiX compile)

    Output: MEPAuto-Setup.msi

    Cài đặt mặc định perUser, KHÔNG cần admin:
      DLL    → %LocalAppData%\MEPAuto\{2022..2027}\MEPAuto.Client.Shell.dll
      .addin → %AppData%\Autodesk\Revit\Addins\{2022..2027}\MEPAuto-{ver}.addin
    Path trong <Assembly> của .addin được patch runtime qua util:XmlFile.
  -->

  <Package
    Name="MEPAuto Revit Add-in"
    Manufacturer="MEPAuto"
    Version="$(var.ProductVersion)"
    UpgradeCode="B2C3D4E5-1000-4002-8002-000000000200"
    InstallerVersion="500"
    Compressed="yes"
    Scope="perUser"
    Codepage="65001"
    Language="1066">

    <MajorUpgrade DowngradeErrorMessage="Phiên bản MEPAuto mới hơn đã được cài. Hãy gỡ trước khi cài bản này." />
    <MediaTemplate EmbedCab="yes" />

    <!-- ===== ARP (Add/Remove Programs) info ===== -->
    <Property Id="ARPHELPLINK" Value="https://github.com/MEP-Automation/MEPAuto/issues" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/MEP-Automation/MEPAuto" />
    <Property Id="ARPCOMMENTS" Value="MEPAuto - bộ tool MEP cho Revit (đa version 2022-2027)." />

    <!-- ===== Detect Revit version đã cài ===== -->
    <Property Id="FORCE_ALL_VERSIONS" Secure="yes" />

    <Property Id="REVIT_2022_INSTALLED">
      <DirectorySearch Id="DirSearch_Revit_2022" Path="[ProgramFiles64Folder]Autodesk\Revit 2022">
        <FileSearch Id="FileSearch_Revit_2022" Name="Revit.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="REVIT_2023_INSTALLED">
      <DirectorySearch Id="DirSearch_Revit_2023" Path="[ProgramFiles64Folder]Autodesk\Revit 2023">
        <FileSearch Id="FileSearch_Revit_2023" Name="Revit.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="REVIT_2024_INSTALLED">
      <DirectorySearch Id="DirSearch_Revit_2024" Path="[ProgramFiles64Folder]Autodesk\Revit 2024">
        <FileSearch Id="FileSearch_Revit_2024" Name="Revit.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="REVIT_2025_INSTALLED">
      <DirectorySearch Id="DirSearch_Revit_2025" Path="[ProgramFiles64Folder]Autodesk\Revit 2025">
        <FileSearch Id="FileSearch_Revit_2025" Name="Revit.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="REVIT_2026_INSTALLED">
      <DirectorySearch Id="DirSearch_Revit_2026" Path="[ProgramFiles64Folder]Autodesk\Revit 2026">
        <FileSearch Id="FileSearch_Revit_2026" Name="Revit.exe" />
      </DirectorySearch>
    </Property>
    <Property Id="REVIT_2027_INSTALLED">
      <DirectorySearch Id="DirSearch_Revit_2027" Path="[ProgramFiles64Folder]Autodesk\Revit 2027">
        <FileSearch Id="FileSearch_Revit_2027" Name="Revit.exe" />
      </DirectorySearch>
    </Property>

    <!-- License agreement embed -->
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseDir)\License.rtf" />

    <!-- ===== Folders (perUser only) =====
         DLL roots: %LocalAppData%\MEPAuto\{ver}\
         .addin roots: %AppData%\Autodesk\Revit\Addins\{ver}\ -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="WixPerUserFolder" Name="MEPAuto">
        <Directory Id="DIR_USER_2022" Name="2022" />
        <Directory Id="DIR_USER_2023" Name="2023" />
        <Directory Id="DIR_USER_2024" Name="2024" />
        <Directory Id="DIR_USER_2025" Name="2025" />
        <Directory Id="DIR_USER_2026" Name="2026" />
        <Directory Id="DIR_USER_2027" Name="2027" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="AppDataFolder">
      <Directory Id="DIR_AUTODESK_USER" Name="Autodesk">
        <Directory Id="DIR_REVIT_USER" Name="Revit">
          <Directory Id="DIR_ADDINS_USER" Name="Addins">
            <Directory Id="ADDIN_USER_2022" Name="2022" />
            <Directory Id="ADDIN_USER_2023" Name="2023" />
            <Directory Id="ADDIN_USER_2024" Name="2024" />
            <Directory Id="ADDIN_USER_2025" Name="2025" />
            <Directory Id="ADDIN_USER_2026" Name="2026" />
            <Directory Id="ADDIN_USER_2027" Name="2027" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- ===== Manifest components — patch <Assembly> path runtime ===== -->
    <Component Id="Manifest_2022" Directory="ADDIN_USER_2022" Guid="*">
      <File Id="ManifestFile_2022" Source="$(var.ManifestDir)\MEPAuto-2022.addin" KeyPath="yes" />
      <util:XmlFile Id="PatchAssembly_2022" File="[#ManifestFile_2022]"
                    ElementPath="/RevitAddIns/AddIn/Assembly" Action="setValue"
                    Value="[WixPerUserFolder]2022\MEPAuto.Client.Shell.dll" Sequence="1" />
    </Component>
    <Component Id="Manifest_2023" Directory="ADDIN_USER_2023" Guid="*">
      <File Id="ManifestFile_2023" Source="$(var.ManifestDir)\MEPAuto-2023.addin" KeyPath="yes" />
      <util:XmlFile Id="PatchAssembly_2023" File="[#ManifestFile_2023]"
                    ElementPath="/RevitAddIns/AddIn/Assembly" Action="setValue"
                    Value="[WixPerUserFolder]2023\MEPAuto.Client.Shell.dll" Sequence="1" />
    </Component>
    <Component Id="Manifest_2024" Directory="ADDIN_USER_2024" Guid="*">
      <File Id="ManifestFile_2024" Source="$(var.ManifestDir)\MEPAuto-2024.addin" KeyPath="yes" />
      <util:XmlFile Id="PatchAssembly_2024" File="[#ManifestFile_2024]"
                    ElementPath="/RevitAddIns/AddIn/Assembly" Action="setValue"
                    Value="[WixPerUserFolder]2024\MEPAuto.Client.Shell.dll" Sequence="1" />
    </Component>
    <Component Id="Manifest_2025" Directory="ADDIN_USER_2025" Guid="*">
      <File Id="ManifestFile_2025" Source="$(var.ManifestDir)\MEPAuto-2025.addin" KeyPath="yes" />
      <util:XmlFile Id="PatchAssembly_2025" File="[#ManifestFile_2025]"
                    ElementPath="/RevitAddIns/AddIn/Assembly" Action="setValue"
                    Value="[WixPerUserFolder]2025\MEPAuto.Client.Shell.dll" Sequence="1" />
    </Component>
    <Component Id="Manifest_2026" Directory="ADDIN_USER_2026" Guid="*">
      <File Id="ManifestFile_2026" Source="$(var.ManifestDir)\MEPAuto-2026.addin" KeyPath="yes" />
      <util:XmlFile Id="PatchAssembly_2026" File="[#ManifestFile_2026]"
                    ElementPath="/RevitAddIns/AddIn/Assembly" Action="setValue"
                    Value="[WixPerUserFolder]2026\MEPAuto.Client.Shell.dll" Sequence="1" />
    </Component>
    <Component Id="Manifest_2027" Directory="ADDIN_USER_2027" Guid="*">
      <File Id="ManifestFile_2027" Source="$(var.ManifestDir)\MEPAuto-2027.addin" KeyPath="yes" />
      <util:XmlFile Id="PatchAssembly_2027" File="[#ManifestFile_2027]"
                    ElementPath="/RevitAddIns/AddIn/Assembly" Action="setValue"
                    Value="[WixPerUserFolder]2027\MEPAuto.Client.Shell.dll" Sequence="1" />
    </Component>

    <!-- ===== Features ===== -->
    <Feature Id="Core" Title="MEPAuto Core" Level="1" AllowAdvertise="no" Display="expand">

      <Feature Id="Revit2022" Title="Revit 2022 (.NET Framework 4.8)" Level="1">
        <Level Value="0" Condition="NOT REVIT_2022_INSTALLED AND NOT FORCE_ALL_VERSIONS" />
        <ComponentRef Id="Manifest_2022" />
        <ComponentGroupRef Id="Files_2022" />
      </Feature>
      <Feature Id="Revit2023" Title="Revit 2023 (.NET Framework 4.8)" Level="1">
        <Level Value="0" Condition="NOT REVIT_2023_INSTALLED AND NOT FORCE_ALL_VERSIONS" />
        <ComponentRef Id="Manifest_2023" />
        <ComponentGroupRef Id="Files_2023" />
      </Feature>
      <Feature Id="Revit2024" Title="Revit 2024 (.NET Framework 4.8)" Level="1">
        <Level Value="0" Condition="NOT REVIT_2024_INSTALLED AND NOT FORCE_ALL_VERSIONS" />
        <ComponentRef Id="Manifest_2024" />
        <ComponentGroupRef Id="Files_2024" />
      </Feature>
      <Feature Id="Revit2025" Title="Revit 2025 (.NET 8)" Level="1">
        <Level Value="0" Condition="NOT REVIT_2025_INSTALLED AND NOT FORCE_ALL_VERSIONS" />
        <ComponentRef Id="Manifest_2025" />
        <ComponentGroupRef Id="Files_2025" />
      </Feature>
      <Feature Id="Revit2026" Title="Revit 2026 (.NET 8)" Level="1">
        <Level Value="0" Condition="NOT REVIT_2026_INSTALLED AND NOT FORCE_ALL_VERSIONS" />
        <ComponentRef Id="Manifest_2026" />
        <ComponentGroupRef Id="Files_2026" />
      </Feature>
      <Feature Id="Revit2027" Title="Revit 2027 (.NET 8)" Level="1">
        <Level Value="0" Condition="NOT REVIT_2027_INSTALLED AND NOT FORCE_ALL_VERSIONS" />
        <ComponentRef Id="Manifest_2027" />
        <ComponentGroupRef Id="Files_2027" />
      </Feature>

    </Feature>

    <!-- UI: Minimal flow (Welcome → License → Progress) -->
    <ui:WixUI Id="WixUI_Minimal" />

  </Package>

</Wix>
