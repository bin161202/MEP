# Sao chép thành .env (KHÔNG commit) và điền giá trị thật.
# .gitignore đã exclude *.env.
#
# Sinh JWT_SIGNING_KEY:
#   openssl rand -base64 48      # 48 byte random, encode base64 → > 32 byte raw key

JWT_SIGNING_KEY=REPLACE_WITH_32_BYTE_RANDOM_KEY_FROM_OPENSSL
JWT_ISSUER=https://api.yourcompany.com
JWT_AUDIENCE=mepauto-client
JWT_REFRESHTOKENHOURS=8
DOMAIN=api.yourcompany.com

# Chọn nginx config (chỉ dùng với variant "container"):
#   nginx.conf            → TLS (cần cert Let's Encrypt cho DOMAIN ở trên)
#   nginx-http-only.conf  → HTTP only (test nội bộ, chưa có domain)
NGINX_CONF=nginx.conf

# Host bind cho variant "system" (docker-compose.system-nginx.yml).
# 127.0.0.1 → chỉ nginx system trên cùng máy proxy_pass tới được (an toàn hơn).
# 0.0.0.0   → expose 8081 ra ngoài (cho test nhanh, không khuyến nghị prod).
HOST_BIND=127.0.0.1
